{
  "name": "@teammates/consolonia",
  "version": "0.1.0",
  "description": "Terminal UI rendering engine inspired by Consolonia. Pixel-level compositing with ANSI output.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "teammates",
    "terminal",
    "tui",
    "ansi",
    "consolonia"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^4.1.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "marked": "^17.0.4"
  }
}
