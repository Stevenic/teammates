<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:TeamMates"
             x:Class="TeamMates.App"
             RequestedThemeVariant="Default">
             <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>

    <Application.Styles>
        <FluentTheme />
        <Style Selector="TabControl.shell-tabs">
            <Setter Property="TabStripPlacement" Value="Left" />
        </Style>
    </Application.Styles>

    <Application.Resources>
        <x:Double x:Key="DenseInlineGap">2</x:Double>
        <x:Double x:Key="SpacingXs">4</x:Double>
        <x:Double x:Key="SpacingSm">8</x:Double>
        <x:Double x:Key="SpacingMd">12</x:Double>
        <x:Double x:Key="SpacingLg">16</x:Double>
        <x:Double x:Key="SpacingXl">24</x:Double>
        <x:Double x:Key="PaneGap">16</x:Double>
        <x:Double x:Key="AvatarSizeSm">32</x:Double>
        <x:Double x:Key="AvatarSizeLg">56</x:Double>
        <x:Double x:Key="TabMinWidth">188</x:Double>
        <x:Double x:Key="BadgeMinWidth">22</x:Double>
        <x:Double x:Key="ComposerMinHeight">42</x:Double>
        <x:Double x:Key="ShellTitleFontSize">24</x:Double>
        <x:Double x:Key="ShellMetaFontSize">12</x:Double>
        <x:Double x:Key="ShellBadgeFontSize">11</x:Double>
        <Thickness x:Key="ControlPadding">12,8</Thickness>
        <Thickness x:Key="SectionPadding">16</Thickness>
        <Thickness x:Key="CardPadding">14</Thickness>
        <Thickness x:Key="HairlineBorderThickness">1</Thickness>
        <Thickness x:Key="TabItemMargin">0,0,0,8</Thickness>
        <Thickness x:Key="FeedItemMargin">0,0,0,12</Thickness>
        <Thickness x:Key="BadgePadding">6,2</Thickness>
        <Thickness x:Key="TargetChipPadding">10,6</Thickness>
        <x:Double x:Key="DenseRowHeight">34</x:Double>
        <CornerRadius x:Key="DefaultCornerRadius">10</CornerRadius>
        <CornerRadius x:Key="AvatarCornerRadiusSm">16</CornerRadius>
        <CornerRadius x:Key="AvatarCornerRadiusLg">28</CornerRadius>
        <CornerRadius x:Key="PillCornerRadius">999</CornerRadius>
    </Application.Resources>
</Application>
