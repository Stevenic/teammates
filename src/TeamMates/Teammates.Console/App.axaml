<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:console="https://github.com/jinek/consolonia"
             x:Class="Teammates.Console.App"
             RequestedThemeVariant="Default">
    <Application.Styles>
        <console:ModernTheme />
        <Style Selector="TabControl.shell-tabs">
            <Setter Property="TabStripPlacement" Value="Left" />
        </Style>
    </Application.Styles>
     <Application.Resources>
        <x:Double x:Key="DenseInlineGap">0</x:Double>
        <x:Double x:Key="SpacingXs">0</x:Double>
        <x:Double x:Key="SpacingSm">0</x:Double>
        <x:Double x:Key="SpacingMd">0</x:Double>
        <x:Double x:Key="SpacingLg">0</x:Double>
        <x:Double x:Key="SpacingXl">0</x:Double>
        <x:Double x:Key="PaneGap">0</x:Double>
        <x:Double x:Key="AvatarSizeSm">0</x:Double>
        <x:Double x:Key="AvatarSizeLg">0</x:Double>
        <x:Double x:Key="TabMinWidth">18</x:Double>
        <x:Double x:Key="BadgeMinWidth">0</x:Double>
        <x:Double x:Key="ComposerMinHeight">3</x:Double>
        <x:Double x:Key="ShellTitleFontSize">1</x:Double>
        <x:Double x:Key="ShellMetaFontSize">1</x:Double>
        <x:Double x:Key="ShellBadgeFontSize">1</x:Double>
        <x:Boolean x:Key="ShowShellAvatars">False</x:Boolean>
        <Thickness x:Key="ControlPadding">0</Thickness>
        <Thickness x:Key="SectionPadding">0</Thickness>
        <Thickness x:Key="CardPadding">0</Thickness>
        <Thickness x:Key="HairlineBorderThickness">1</Thickness>
        <Thickness x:Key="TabItemMargin">0</Thickness>
        <Thickness x:Key="FeedItemMargin">0</Thickness>
        <Thickness x:Key="BadgePadding">0</Thickness>
        <Thickness x:Key="TargetChipPadding">1,0</Thickness>
        <x:Double x:Key="DenseRowHeight">1</x:Double>
        <CornerRadius x:Key="DefaultCornerRadius">0</CornerRadius>
        <CornerRadius x:Key="AvatarCornerRadiusSm">0</CornerRadius>
        <CornerRadius x:Key="AvatarCornerRadiusLg">0</CornerRadius>
        <CornerRadius x:Key="PillCornerRadius">0</CornerRadius>
    </Application.Resources>
</Application>
